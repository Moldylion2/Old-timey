Foreign: [+ foreign_minister +] ([?if foreign_minister_party=="I":<span style="color: #808080;">**I**</span>?][?if foreign_minister_party=="Labour":<span style="color: #E3000F;">**Labour**</span>?][?if foreign_minister_party==liberals_name:<span style="color: #DCCA4A;">**[+liberals_name+]**</span>?][?if foreign_minister_party=="Tory":<span style="color: #0087DC;">**Tory**</span>?][?if foreign_minister_party==dvp_name:<span style="color: var(--dvp-color);">**[+ dvp_name +]**</span>?][?if foreign_minister_party=="DNVP":<span style="color: #3F7BC1;">**DNVP**</span>?][?if foreign_minister_party=="DNF":<span style="color: #003755;">**DNF**</span>?][?if foreign_minister_party=="NSDAP":<span style="color: #954B00;">**NSDAP**</span>?])

