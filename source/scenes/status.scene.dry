title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
    var _newData = [];
    function _addP(id, legend, seats) {
        if (seats && seats > 0) _newData.push({ id: id, legend: legend, name: legend, seats: seats });
    }
    _addP('labour', 'Labour', Q.labour_r);
    _addP('liberals', 'Liberals', Q.liberals_r);
    _addP('tories', 'Tories', Q.tories_r);
    _addP('cpgb',  'CPGB',  Q.cpgb_r);
    _addP('other', 'Other', Q.other_r);
    var _newSig = JSON.stringify(_newData.map(function(p){ return p.id + p.seats; }));
    var _changed = (_newSig !== window._parliSig);
    window._parliData = _newData;
    if (_changed) {
        window._parliSig = _newSig;
        window._parliAnimate = true;
    } else {
        window._parliAnimate = false;
    }
!}

= Status

[+ month : month +] [+ year +]

Resources available: [+ resources +]

Labour position: [? if labour_toleration : toleration ?][? if labour_in_government : in government - ?][? if labour_toleration == 0 and labour_in_government == 0 and labour_caretaker == 0 : opposition ?][? if labour_caretaker : caretaker government ?]
[? if in_labour_majority and labour_in_government: Labour majority ?][? if in_labour_minority_government : Labour minority ?]

[? if in_labour_minority_government: Liberal dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if labour_in_government and (in_left_front or in_popular_front): CPGB coalition dissent: [+ cpgb_coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

= Government

King: [+ king +]

Prime Minister: [+ prime_minister +] ([?if prime_minister_party=="I":<span style="color: #808080;">**I**</span>?][?if prime_minister_party=="Labour":<span style="color: #E4003B;">**Labour**</span>?][?if prime_minister_party==liberals_name:<span style="color: #FAA61A;">**Liberal**</span>?][?if prime_minister_party==dvp_name:<span style="color: var(--dvp-color);">**[+ dvp_name +]**</span>?][?if prime_minister_party=="Tory":<span style="color: #0087DC;">**Tory**</span>?][?if prime_minister_party=="NSDAP":<span style="color: #954B00;">**NSDAP**</span>?])

Leader of the Opposition [+ opposition_leader +] ([+ opposition_leader_party +])

Parliament composition:

{!<svg id="status_parliament" style="width: 100%; height: 195px; display: block;"></svg>
<script>
(function() {
    if (!d3 || !d3.parliament || !window._parliData || window._parliData.length === 0) return;
    var el = document.getElementById('status_parliament');
    if (!el) return;
    var w = el.parentElement.offsetWidth || 220;
    el.setAttribute('width', w);
    el.setAttribute('height', Math.round(w * 0.55));
    var parl = d3.parliament();
    parl.width(w).height(Math.round(w * 0.55)).innerRadiusCoef(0.4);
    var animate = window._parliAnimate;
    parl.enter.fromCenter(animate).smallToBig(animate);
    parl.exit.toCenter(animate).bigToSmall(animate);
    d3.select('#status_parliament').datum(window._parliData).call(parl);
})();
</script>!}

{!<span class="tooltip-text" title="The Labour Party"style="color: #E4003B;">!}**Labour**{!</span>!}: [+ labour_seats +] ([+ labour_r +]%)   
{!<span class="tooltip-text" title="The Conservative Party"style="color: #0087DC;">!}**Tories**{!</span> !}: [+ tories_seats +] ([+ tories_r +]%)
{!<span class="tooltip-text" title="The Liberal Party"style="color: #FFBF00;">!}**Liberals**{!</span>!}: [+ liberals_seats +] ([+ liberals_r +]%)
{!<span class="tooltip-text" title="Communist Party of Great Britain"style="color: #8B0000;">!}**CPGB**{!</span>:!}: [+ cpgb_seats +] ([+ cpgb_r +]%)
<span style="color: #909090;">**Others**</span>: [+ other_seats +] ([+ other_r +]%)

[? if labour_in_government == 1 : Budget: [+ budget +] ?]

Next election: [+ next_election_month : month +] [+ next_election_year +]

= Economics

Inflation: [+ inflation_2 +]%

Unemployment: [+ unemployed_2 +]%

Economic growth: [+ economic_growth_2 +]%


