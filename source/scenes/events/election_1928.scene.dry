title: House of Commons Elections
new-page: true
tags: event
priority: -1
view-if: (year == next_election_year and month >= next_election_month) or (year > next_election_year)
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 5; n_elections += 1; next_election_time = time + 48; papen_chancellor_timer = 4;
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

# the low priority means that this event is only seen after all other events are resolved for the month.

= Elections, [+ month : month +] [+ year +]

The House of Commons are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48. This is likely to be extremely unpopular both with our base and with the other parties. However, this may be necessary to prevent the extremists from gaining power.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-departure: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; dvp_relation -= 8; elation -= 8; liberals_relation -= 10; cpgb_relation -= 8; coup_progress += 2; workers_spd -= 4; new_middle_spd -= 5; old_middle_spd -= 5; rural_spd -= 5; catholics_spd -= 5; unemployed_spd -= 5;
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

Let us hope this does not backfire.

@post_election_1928
on-arrival: {!
// set old results
// election threshold constitutional reform
// banning parties

var new_party_sum = 0;
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'];
    Q['old_' + party + '_seats'] = Q[party + '_seats'];
    if (Q.electoral_threshold > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || (Q.electoral_threshold > 1 && party == 'other') || Q[party + '_banned']) {
            Q[party + '_r'] = 0;
        } else {
            Q[party + '_r'] = parseFloat((Q[party+'_votes']).toFixed(1));
        }
        new_party_sum += Q[party + '_r'];
    } else {
        Q[party + '_r'] = parseFloat((Q[party+'_votes']).toFixed(1));
        if (party == 'other') Q[party + '_r'] = Q[party + '_votes'] * 0.3;
        new_party_sum += Q[party + '_r'];
    }

    Q['change_' + party + '_votes'] = Q[party + '_votes'] - Q['old_' + party + '_votes'];
    var sign2 = Q['change_' + party + '_votes'] > 0
                    ? '<img src="img/arrowup.png"> '
                    : Q['change_' + party + '_votes'] < 0
                      ? '<img src="img/arrowdown.png"> '
                      : '<img src="img/steady.png"> ';
    Q['votes_change_' + party] = sign2 + Math.abs(parseFloat(Q['change_' + party + '_votes'])).toFixed(1);

    Q['old_' + party + '_votes'] = parseFloat((Q[party + '_votes']).toFixed(1));
}

for (var party of Q.parties) {
    if (Q[party + '_r'] > 0) {
        Q[party + '_r'] = Math.round(Q[party + '_r']*1000/new_party_sum)/10;
    }
    Q[party + '_r'] = parseFloat((Q[party+'_r']).toFixed(1));
}

let allocatedSeats = 0;
let remainders = [];

for (var party of Q.parties) {
    let rawSeats = Q[party + '_r'] * Math.round(Q.reichstag_size*100) / 100;
    let seats = Math.floor(rawSeats);
    Q[party + '_seats'] = seats;
    allocatedSeats += seats;
    remainders.push({
        party: party,
        remainder: rawSeats - seats
    });
}

let remainingSeats = Math.round(Q.reichstag_size*100) - allocatedSeats;
remainders.sort((a, b) => b.remainder - a.remainder);
for (let i = 0; i < remainingSeats && i < remainders.length; i++) {
    let partyObj = remainders[i];
    if (!partyObj || !partyObj.party) continue;

    let party = partyObj.party;
    Q[party + '_seats'] += 1;
}

// Calculate total seats distributed for majority calculations
Q.total_seats_distributed = allocatedSeats + Math.min(remainingSeats, remainders.length);

for (var party of Q.parties) {
    Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
    var sign = Q['change_' + party + '_r'] > 0
            ? '<img src="img/arrowup.png"> '
            : Q['change_' + party + '_r'] < 0
                    ? '<img src="img/arrowdown.png"> '
                    : '<img src="img/steady.png"> ';
    Q['str_change_' + party] = sign + Math.abs(parseFloat(Q['change_' + party + '_r'])).toFixed(1);

    Q['change_' + party + '_seats'] = Q[party + '_seats'] - Q['old_' + party + '_seats'];
    var sign = Q['change_' + party + '_seats'] > 0
            ? '<img src="img/arrowup.png"> '
            : Q['change_' + party + '_seats'] < 0
                    ? '<img src="img/arrowdown.png"> '
                    : '<img src="img/steady.png"> ';
    Q['str_seats_change_' + party] = sign + Math.abs(Q['change_' + party + '_seats']);
}

// Fixed opposition logic (compare seats to seats)
if (Q.labour_seats > Q.tories_seats && Q.tories_seats > Q.liberals_seats) {
    Q.opposition_party = 'Tories';
} else if (Q.tories_seats > Q.labour_seats && Q.labour_seats > Q.liberals_seats) {
    Q.opposition_party = 'Labour';
} else {
    Q.opposition_party = 'Liberals';
}

// Dynamically track Largest and Second Largest party
var sortedParties = Q.parties.map(p => ({name: p, seats: Q[p + '_seats']})).sort((a, b) => b.seats - a.seats);

if (sortedParties[0]) {
    if (sortedParties[0].name == 'labour') Q.largest_party = 'Labour';
    else if (sortedParties[0].name == 'tories') Q.largest_party = 'Tories';
    else if (sortedParties[0].name == 'liberals') Q.largest_party = 'Liberals';
    else if (sortedParties[0].name == 'cpgb') Q.largest_party = 'CPGB';
    else Q.largest_party = 'Other';
}

if (sortedParties[1]) {
    if (sortedParties[1].name == 'labour') Q.second_largest_party = 'Labour';
    else if (sortedParties[1].name == 'tories') Q.second_largest_party = 'Tories';
    else if (sortedParties[1].name == 'liberals') Q.second_largest_party = 'Liberals';
    else if (sortedParties[1].name == 'cpgb') Q.second_largest_party = 'CPGB';
    else Q.second_largest_party = 'Other';
}

Q.opposition_party = Q.second_largest_party;
Q.opposition_leader = Q.opposition_party;

Q.majority_needed = Math.floor(Q.total_seats_distributed / 2) + 1;

// Cleaned British Coalitions (majority is held by seats, not raw vote share)
Q.labour_majority       = (Q.labour_seats   >= Q.majority_needed) ? 1 : 0;
Q.conservative_majority = (Q.tories_seats   >= Q.majority_needed) ? 1 : 0;
Q.liberals_majority     = (Q.liberals_seats >= Q.majority_needed) ? 1 : 0;

Q.hung_parliament = (!Q.labour_majority && !Q.conservative_majority && !Q.liberals_majority) ? 1 : 0;

// Lab-Lib minority: the leader must out-seat its partner AND the two together out-seat the Tories
var lab_lib = Q.labour_seats + Q.liberals_seats;
Q.no_majority_labour       = (Q.hung_parliament && Q.labour_seats   > Q.liberals_seats && lab_lib > Q.tories_seats) ? 1 : 0;
Q.no_majority_liberals     = (Q.hung_parliament && Q.liberals_seats > Q.labour_seats   && lab_lib > Q.tories_seats) ? 1 : 0;
Q.no_majority_conservative = (Q.hung_parliament && !Q.no_majority_labour && !Q.no_majority_liberals) ? 1 : 0;

Q.coalition_dissent = 0;
Q.kpd_coalition_dissent = 0;
Q.labour_in_government = 0;
Q.tories_in_government = 0;
Q.liberals_in_government = 0;

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
on-departure: nazi_urgency = 1 if (nazi_urgency == 0 and cpgb_r >= 15)
on-display: {!
data = [
    {
        "id": "cpgb",
        "legend": "CPGB",
        "name": "CPGB",
        "seats": Math.round(Q.cpgb_seats),
    },
    {
        "id": "labour",
        "legend": "Labour",
        "name": "Labour",
        "seats": Math.round(Q.labour_seats),
    },
    {
        "id": "liberals",
        "legend": "Liberals",
        "name": "Liberals",
        "seats": Math.round(Q.liberals_seats),
    },
    {
        "id": "tories",
        "legend": "Tories",
        "name": "Tories",
        "seats": Math.round(Q.tories_seats),
    },
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_seats),
    },
];

if (window && d3) {
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    }

    var parliament = d3.parliament();
     parliament.width(width).height(height).innerRadiusCoef(0.4);
     parliament.enter.fromCenter(true).smallToBig(true);
     parliament.exit.toCenter(false).bigToSmall(true);
     d3.select("#reichstag").datum(data).call(parliament);
}
!}
go-to: coalition_menu

[? if largest_party == "Tories" and tories_seats >= majority_needed : The Conservatives have won an outright majority! ?]
[? if largest_party == "Tories" and tories_seats < majority_needed : The Conservatives remain the largest party, but they don’t have an outright majority, so they need Liberals tolerate them. ?]
[? if largest_party == "Labour" and labour_seats >= majority_needed : The Labour Party has won an outright majority! This is a historic victory. ?]
[? if largest_party == "Labour" and labour_seats < majority_needed : The Labour Party has emerged as the largest party! However, they lack an outright majority. ?]
[? if second_largest_party == "Labour" : We are the second largest party in parliament, meaning we will form the official opposition. ?]
[? if second_largest_party == "Tories" : The Tories have been pushed back into opposition—this is a major tactical shift. ?]



